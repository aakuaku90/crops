# Google Earth Engine Cloud project ID (the project you registered at code.earthengine.google.com/register)
GEE_PROJECT_ID=your-cloud-project-id

# Google Cloud Storage bucket for batch exports (create with: gcloud storage buckets create gs://...)
GCS_BUCKET=ghana-maize-exports

# Default AOI country code (kept here so scripts stay parameterized)
COUNTRY_NAME=Ghana
